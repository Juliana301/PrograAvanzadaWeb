@{
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
    ViewData["Title"] = "Register";
}

<div class="bg-white dark:bg-surface-800 rounded-2xl border border-surface-200 dark:border-surface-700 shadow-xl shadow-surface-200/50 dark:shadow-surface-950/50 p-8">

    <form asp-controller="Authentication" asp-action="Register" method="post">

        <!-- Full Name -->
        <div class="mb-5">

            <label class="block text-sm font-medium text-surface-700 mb-1.5">
                Nombre completo
            </label>

            <input type="text"
                   name="fullname"
                   placeholder="Juan Perez"
                   required
                   class="w-full px-4 py-2.5 rounded-xl border border-surface-200" />

        </div>


        <!-- Email -->
        <div class="mb-5">

            <label class="block text-sm font-medium text-surface-700 mb-1.5">
                Correo electrónico
            </label>

            <input type="email"
                   name="email"
                   placeholder="correo@ejemplo.com"
                   required
                   class="w-full px-4 py-2.5 rounded-xl border border-surface-200" />

        </div>


        <!-- Username -->
        <div class="mb-5">

            <label class="block text-sm font-medium text-surface-700 mb-1.5">
                Usuario
            </label>

            <input type="text"
                   name="username"
                   placeholder="juanperez"
                   required
                   class="w-full px-4 py-2.5 rounded-xl border border-surface-200" />

        </div>


        <!-- Password -->
        <div class="mb-5">

            <label class="block text-sm font-medium text-surface-700 mb-1.5">
                Contraseña
            </label>

            <input type="password"
                   name="password"
                   required
                   minlength="6"
                   class="w-full px-4 py-2.5 rounded-xl border border-surface-200" />

        </div>


        <!-- Confirm Password -->
        <div class="mb-6">

            <label class="block text-sm font-medium text-surface-700 mb-1.5">
                Confirmar contraseña
            </label>

            <input type="password"
                   name="confirmPassword"
                   required
                   minlength="6"
                   class="w-full px-4 py-2.5 rounded-xl border border-surface-200" />

        </div>


        @if (ViewBag.Error != null)
        {
            <div class="mb-4 p-3 rounded-xl bg-red-50 border border-red-200 text-red-600 text-sm">
                @ViewBag.Error
            </div>
        }


        <button type="submit"
                class="w-full px-4 py-3 rounded-xl bg-brand-500 text-white font-semibold">

            Crear cuenta

        </button>

    </form>

</div>


<div class="mt-6 text-center">

    <p class="text-sm text-surface-500">

        ¿Ya tienes cuenta?

        <a asp-controller="Authentication"
           asp-action="Login"
           class="text-brand-600 hover:underline">

            Inicia sesión

        </a>

    </p>

</div>